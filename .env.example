# Copy this file to .env and fill in real values for local development.
# In production, these are set via Render's dashboard (see render.yaml).
#
# IMPORTANT: never commit .env to git.

# --- Our own Postgres (faults table) ---
# Local dev: install Postgres locally OR use a free Render/Supabase instance.
# Format: postgresql://user:password@host:port/dbname
OUR_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/loker_faults

# --- Adon Locker DB (Netanel's Supabase) — READ-ONLY ---
# Get the password from Netanel. ALWAYS append ?sslmode=require for Supabase.
ADON_LOCKER_DATABASE_URL=postgresql://USER:PASSWORD@db.imlunhybtfwxlvrvfhic.supabase.co:5432/postgres?sslmode=require

# --- Google OAuth ---
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs:
#   http://localhost:5000/auth/callback        (dev)
#   https://<your-render-url>/auth/callback    (prod)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Comma-separated list of emails allowed to log in.
ALLOWED_EMAILS=talyacu@gmail.com

# Random secret for Flask sessions. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-long-random-string

# --- Optional ---
# How long student/locker data is cached in app memory (seconds).
ADON_CACHE_TTL_SECONDS=60

# Set to 1 only for local dev. Never enable in production.
FLASK_DEBUG=0
